{
  "name": "lian-nest-server",
  "version": "0.1.0",
  "private": true,
  "description": "Nest-first backend rewrite for LIAN",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "nest build",
    "check": "tsc --noEmit",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest --runInBand",
    "test:boundary": "jest --runInBand --testPathPattern=repository-boundary",
    "test:cov": "jest --coverage",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "postinstall": "prisma generate",
    "guard:boundary": "node scripts/guards/check-task-boundary.js",
    "guard:pr-handoff": "node scripts/guards/check-pr-handoff.js",
    "guard:docs-authority": "node scripts/guards/check-docs-authority.js",
    "guard:generated-prisma": "node scripts/guards/check-generated-prisma.js",
    "guard:nodebb-adapter-boundary": "node scripts/guards/check-nodebb-adapter-boundary.js",
    "guard:repository-boundary": "node scripts/check-repository-boundary.js",
    "guard:route-parity": "node scripts/check-route-parity.js",
    "ops:guard": "npm run guard:repository-boundary && npm run guard:docs-authority && npm run guard:generated-prisma && npm run guard:nodebb-adapter-boundary",
    "ops:health": "node scripts/post-merge-health-gate.js --quick",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "ioredis": "^5.10.1",
    "joi": "^17.13.3",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "jest": "^29.7.0",
    "prisma": "^7.8.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "setupFiles": [
      "../test/setup-env.ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.module.ts",
      "!main.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
