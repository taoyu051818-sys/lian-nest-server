  {
    "id": "feed-item-invalid-id-empty",
    "endpoint": "GET /api/feed/:feedItemId",
    "description": "Empty feedItemId returns 404",
    "request": {
      "method": "GET",
      "path": "/api/feed/",
      "params": { "feedItemId": "" },
      "query": {},
      "headers": {}
    },
    "expected": {
      "status": 404,
      "contentType": "application/json",
      "body": { "statusCode": 404, "error": "Not Found" },
      "bodySchema": {
        "type": "object",
        "required": ["statusCode", "error"],
        "properties": {
          "statusCode": { "type": "integer", "const": 404 },
          "error": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "notes": "Empty string fails /^t(\\d+)$/ regex in GetFeedItemUsecase.parseFeedItemId."
  },
