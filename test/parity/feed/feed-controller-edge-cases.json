  {
    "id": "feed-query-coercion-page-string",
    "endpoint": "GET /api/feed",
    "description": "String page value '2' coerces to number 2",
    "request": {
      "method": "GET",
      "path": "/api/feed",
      "query": { "page": "2", "perPage": "10" },
      "params": {},
      "headers": {}
    },
    "expected": {
      "status": 200,
      "contentType": "application/json",
      "body": {
        "page": 2,
        "perPage": 10
      },
      "bodySchema": {
        "type": "object",
        "required": ["items", "totalCount", "page", "perPage"],
        "properties": {
          "items": { "type": "array" },
          "totalCount": { "type": "integer", "minimum": 0 },
          "page": { "type": "integer", "const": 2 },
          "perPage": { "type": "integer", "const": 10 }
        },
        "additionalProperties": false
      }
    },
    "notes": "class-transformer @Type(() => Number) coerces string '2' to integer 2 via ValidationPipe."
  },
