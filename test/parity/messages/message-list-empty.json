{
  "id": "message-list-empty",
  "endpoint": "GET /api/messages",
  "description": "Authenticated user with no messages receives empty collection",
  "request": {
    "method": "GET",
    "path": "/api/messages"
  },
  "expected": {
    "status": 200,
    "contentType": "application/json",
    "body": {
      "messages": [],
      "totalCount": 0,
      "page": 1,
      "perPage": 20
    },
    "bodySchema": {
      "type": "object",
      "required": ["messages", "totalCount", "page", "perPage"],
      "properties": {
        "messages": {
          "type": "array",
          "maxItems": 0
        },
        "totalCount": { "type": "integer", "const": 0 },
        "page": { "type": "integer", "const": 1 },
        "perPage": { "type": "integer", "const": 20 }
      },
      "additionalProperties": false
    }
  },
  "notes": "Empty state must return 200, not 404. Validates graceful empty-collection behavior."
}
