{
  "id": "topic-detail-not-found",
  "endpoint": "GET /api/topic/:tid",
  "description": "Requesting a non-existent topic returns 404 with standard error envelope",
  "request": {
    "method": "GET",
    "path": "/api/topic/999999999",
    "params": { "tid": "999999999" }
  },
  "expected": {
    "status": 404,
    "contentType": "application/json",
    "body": { "statusCode": 404, "error": "Not Found", "code": "NOT_FOUND" },
    "bodySchema": {
      "type": "object",
      "required": ["statusCode", "error", "code"],
      "properties": {
        "statusCode": { "type": "integer", "const": 404 },
        "error": { "type": "string" },
        "code": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "notes": "Topic ID 999999999 is chosen to be unreachable. The error envelope follows the GlobalExceptionFilter format."
}
