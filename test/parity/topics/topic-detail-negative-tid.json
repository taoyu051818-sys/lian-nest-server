{
  "id": "topic-detail-negative-tid",
  "endpoint": "GET /api/topic/:tid",
  "description": "Requesting a topic with a negative tid returns 404",
  "request": {
    "method": "GET",
    "path": "/api/topic/-1",
    "params": { "tid": "-1" }
  },
  "expected": {
    "status": 404,
    "contentType": "application/json",
    "body": { "statusCode": 404, "error": "Not Found", "code": "NOT_FOUND" },
    "bodySchema": {
      "type": "object",
      "required": ["statusCode", "error", "code"],
      "properties": {
        "statusCode": { "type": "integer", "const": 404 },
        "error": { "type": "string" },
        "code": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "notes": "Negative tid=-1 fails the tid <= 0 check in TopicsUsecase.getByTid."
}
