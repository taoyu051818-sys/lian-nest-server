{
  "id": "groups-list-empty",
  "endpoint": "GET /api/groups",
  "description": "Groups list returns empty items when upstream has no groups",
  "request": {
    "method": "GET",
    "path": "/api/groups"
  },
  "expected": {
    "status": 200,
    "contentType": "application/json",
    "body": {
      "groups": [],
      "source": "nodebb"
    },
    "bodySchema": {
      "type": "object",
      "required": ["groups", "source"],
      "properties": {
        "groups": {
          "type": "array",
          "items": { "$ref": "#/$defs/GroupItem" }
        },
        "source": { "type": "string", "enum": ["nodebb", "fallback"] }
      },
      "additionalProperties": false,
      "$defs": {
        "GroupItem": {
          "type": "object",
          "required": ["name", "slug", "description", "memberCount", "hidden", "deleted", "createtime"],
          "properties": {
            "name": { "type": "string" },
            "slug": { "type": "string" },
            "description": { "type": "string" },
            "memberCount": { "type": "integer", "minimum": 0 },
            "hidden": { "type": "boolean" },
            "deleted": { "type": "boolean" },
            "createtime": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      }
    }
  },
  "notes": "Returned when NodeBB groups list is empty. Source remains 'nodebb' because the upstream responded successfully with no groups."
}
