{
  "id": "tag-topics-invalid-pagination",
  "endpoint": "GET /api/tags/:tag/topics",
  "description": "Tag topics coerces invalid pagination to defaults",
  "request": {
    "method": "GET",
    "path": "/api/tags/<TAG>/topics",
    "params": { "tag": "<TAG>" },
    "query": { "page": -1, "perPage": 999 }
  },
  "expected": {
    "status": 200,
    "contentType": "application/json",
    "body": {
      "topics": [],
      "source": "nodebb",
      "totalCount": "<NON_NEG_INT>",
      "page": 1,
      "perPage": 100
    },
    "bodySchema": {
      "type": "object",
      "required": ["topics", "source", "totalCount", "page", "perPage"],
      "properties": {
        "topics": {
          "type": "array",
          "items": { "$ref": "#/$defs/TagTopicItem" }
        },
        "source": { "type": "string", "enum": ["nodebb", "fallback"] },
        "totalCount": { "type": "integer", "minimum": 0 },
        "page": { "type": "integer", "minimum": 1 },
        "perPage": { "type": "integer", "minimum": 1, "maximum": 100 }
      },
      "additionalProperties": false,
      "$defs": {
        "TagTopicItem": {
          "type": "object",
          "required": ["tid", "uid", "cid", "title", "slug", "mainPid", "postcount", "viewcount", "timestamp"],
          "properties": {
            "tid": { "type": "integer", "minimum": 1 },
            "uid": { "type": "integer", "minimum": 1 },
            "cid": { "type": "integer", "minimum": 1 },
            "title": { "type": "string" },
            "slug": { "type": "string" },
            "mainPid": { "type": "integer", "minimum": 1 },
            "postcount": { "type": "integer", "minimum": 0 },
            "viewcount": { "type": "integer", "minimum": 0 },
            "timestamp": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      }
    }
  },
  "notes": "Negative page is coerced to 1. perPage exceeding 100 is clamped to 100. Non-numeric values fall back to defaults (page=1, perPage=20)."
}
